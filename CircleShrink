
import javafx.application.Application;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.control.Button;
import javafx.scene.layout.BorderPane;
import javafx.scene.layout.HBox;
import javafx.scene.layout.StackPane;
import javafx.scene.paint.Color;
import javafx.scene.shape.Circle;
import javafx.stage.Stage;

public class CircleShrink extends Application {

	@Override
	public void start(Stage primaryStage) {
		BorderPane pane = new BorderPane();
		
		StackPane c = new StackPane();
		Circle circle = new Circle();
		circle.setRadius(2);
		circle.setCenterX(50);
		circle.setCenterY(50);
		circle.setFill(Color.WHITE);
		circle.setStroke(Color.BLACK);
		c.getChildren().add(circle);
		
		pane.setCenter(c);
		
		
		HBox hbox = new HBox(20);
		Button shrink = new Button("Shrink");
		Button enlarge = new Button("Enlarge");
		hbox.getChildren().addAll(shrink, enlarge);
		hbox.setAlignment(Pos.CENTER);
		
		pane.setBottom(hbox);
		
		
		shrink.setOnAction(e->{
			if(circle.getRadius() > 2) {
			circle.setRadius(circle.getRadius() - 2);
			}});
		
		enlarge.setOnAction(e->{
			circle.setRadius(circle.getRadius() + 2);
		});
		
		
		Scene scene = new Scene(pane, 400, 400);
		
		primaryStage.setTitle("Circle Control");
		primaryStage.setScene(scene);
		primaryStage.show();
		
	}

	public static void main(String[] args) {
		launch(args);

	}

}
