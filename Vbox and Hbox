package Final;

import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.scene.Scene;
import javafx.scene.control.Button;
import javafx.scene.control.Label;
import javafx.scene.layout.BorderPane;
import javafx.scene.layout.HBox;
import javafx.scene.layout.VBox;
import javafx.stage.Stage;

public class ShowHboxVbox extends Application {

	@Override
	public void start(Stage primaryStage) throws Exception {
		BorderPane pane = new BorderPane();
		
		pane.setTop(ShowHbox());
		pane.setBottom(ShowVbox());
		
		
		Scene scene = new Scene(pane);
		
		primaryStage.setTitle("Hbox and Vbox");
		primaryStage.setScene(scene);
		primaryStage.show();
	}
	
	protected HBox ShowHbox() {
		HBox hbox = new HBox(15);
		hbox.setPadding(new Insets(5, 5, 5, 5));
		hbox.setStyle("-fx-background-color: gold");
		hbox.getChildren().add(new Button("Chemistry"));
		hbox.getChildren().add(new Button("Comp Science"));
		//ImageView image = new ImageView(new Image("image/us.gif"));
		//hbox.getChildren().add(image);
		
		return hbox;
	}
	
	protected VBox ShowVbox() {
		VBox vbox = new VBox(15);
		vbox.setPadding(new Insets(5, 5, 5, 5));
		vbox.getChildren().add(new Label("Courses"));
		
		Label[] course = {new Label("CST 2011"), new Label("CST 2021"),
				new Label("CST 2031"), new Label("CST 2041"),new Label("CST 2051")};
		
		/*for(Label courses: course){
			VBox.setMargin(courses, new Insets(0, 0, 0, 15));
			vbox.getChildren().add(course);}
		*/
		
		vbox.getChildren().addAll(course);
 		
		
		return vbox;
	}

	public static void main(String[] args) {
		launch(args);

	}

}
