
import javafx.application.Application;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.control.Button;
import javafx.scene.control.Label;
import javafx.scene.control.RadioButton;
import javafx.scene.control.TextField;
import javafx.scene.control.ToggleGroup;
import javafx.scene.layout.GridPane;
import javafx.scene.layout.HBox;
import javafx.scene.text.Font;
import javafx.scene.text.FontWeight;
import javafx.scene.text.Text;
import javafx.stage.Stage;

public class StudentRegistration extends Application {

	@Override
	public void start(Stage primaryStage) {
		
		GridPane pane = new GridPane();
		pane.setAlignment(Pos.CENTER);
		pane.setHgap(20);
		pane.setVgap(20);
		
		Text text = new Text("Student Registration");
		text.setFont(Font.font("Times New Roman", FontWeight.BOLD, 20));
		
		pane.add(text, 0, 0);
		
		pane.add(new Label("Name: "), 0, 1);
		pane.add(new TextField(), 1, 1);
		
		pane.add(new Label("Father Name: "), 0, 2);
		pane.add(new TextField(), 1, 2);
		
		HBox hbox = new HBox(50);
		RadioButton male = new RadioButton("Male");
		RadioButton female = new RadioButton("Female");
		hbox.getChildren().addAll(male, female);
		
		ToggleGroup group = new ToggleGroup();
		male.setToggleGroup(group);
		female.setToggleGroup(group);
		
		pane.add(new Label("Gender: "), 0, 3);
		pane.add(hbox, 1, 3);
		
		pane.add(new Label("Acedemic Year: "), 0, 4);
		pane.add(new TextField(), 1, 4);
		pane.add(new Label("Address: "), 0, 5);
		pane.add(new TextField(), 1, 5);
		
		pane.add(new Label("Email: "), 0, 6);
		pane.add(new TextField(), 1, 6);
		
		HBox btn = new HBox(20);
		Button rbtn = new Button("Register");
		Button cbtn = new Button("Clear");
		btn.getChildren().addAll(rbtn, cbtn);
		btn.setAlignment(Pos.BOTTOM_RIGHT);
		pane.add(btn, 1, 7);
		
		
		Scene scene = new Scene(pane, 400, 400);
		
		primaryStage.setTitle("Student registartion");
		primaryStage.setScene(scene);
		primaryStage.show();
		
		

	}

	public static void main(String[] args) {
		launch(args);

	}

}
