
import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.control.*;
import javafx.scene.layout.*;
import javafx.stage.Stage;
import java.io.BufferedWriter;
import java.io.FileWriter;
import java.io.IOException;

public class StudentRegistration extends Application {

    @Override
    public void start(Stage primaryStage) {
        // Labels
        Label lblName = new Label("Student Name:");
        Label lblFather = new Label("Father Name:");
        Label lblGender = new Label("Gender:");
        Label lblYear = new Label("Academic Year:");
        Label lblAddress = new Label("Address:");
        Label lblEmail = new Label("Email:");

        // Input fields
        TextField txtName = new TextField();
        txtName.setPrefColumnCount(20);
        TextField txtFather = new TextField();
        txtFather.setPrefColumnCount(20);

        // Gender RadioButtons
        ToggleGroup genderGroup = new ToggleGroup();
        RadioButton rdoMale = new RadioButton("Male");
        RadioButton rdoFemale = new RadioButton("Female");
        rdoMale.setToggleGroup(genderGroup);
        rdoFemale.setToggleGroup(genderGroup);

        HBox genderBox = new HBox(10, rdoMale, rdoFemale);

        // ComboBox for Academic Year
        String[] years = {"First Year", "Second Year", "Third Year", "Fourth Year", "Fifth Year"};
        ComboBox<String> cmbYear = new ComboBox<>();
        cmbYear.getItems().addAll(years);
        cmbYear.setValue("First Year");

        TextArea txtAddress = new TextArea();
        txtAddress.setPrefRowCount(3);
        txtAddress.setPrefColumnCount(20);

        TextField txtEmail = new TextField();
        txtEmail.setPrefColumnCount(20);

        // Save Button
        Button btnSave = new Button("Save");

        btnSave.setOnAction(e -> {
            String name = txtName.getText();
            String father = txtFather.getText();
            String gender = "";
            if (genderGroup.getSelectedToggle() != null) {
                gender = ((RadioButton) genderGroup.getSelectedToggle()).getText();
            }
            String year = cmbYear.getValue();
            String address = txtAddress.getText();
            String email = txtEmail.getText();

            // Save to file using Text I/O
            try (BufferedWriter writer = new BufferedWriter(new FileWriter("StudentRegistration.txt", true))) {
                writer.write("Name: " + name);
                writer.newLine();
                writer.write("Father Name: " + father);
                writer.newLine();
                writer.write("Gender: " + gender);
                writer.newLine();
                writer.write("Academic Year: " + year);
                writer.newLine();
                writer.write("Address: " + address);
                writer.newLine();
                writer.write("Email: " + email);
                writer.newLine();
                writer.write("---------------------------");
                writer.newLine();

                Alert alert = new Alert(Alert.AlertType.INFORMATION, "Data Saved Successfully!");
                alert.show();

                // Clear form
                txtName.clear();
                txtFather.clear();
                genderGroup.selectToggle(null);
                cmbYear.setValue(null);
                txtAddress.clear();
                txtEmail.clear();

            } catch (IOException ex) {
                Alert alert = new Alert(Alert.AlertType.ERROR, "Error saving data: " + ex.getMessage());
                alert.show();
            }
        });

        // Layout with GridPane
        GridPane grid = new GridPane();
        grid.setAlignment(Pos.CENTER);
        grid.setHgap(10);
        grid.setVgap(10);
        grid.setPadding(new Insets(25, 25, 25, 25));
        
        grid.add(lblName, 0, 0);
        grid.add(txtName, 1, 0);

        grid.add(lblFather, 0, 1);
        grid.add(txtFather, 1, 1);

        grid.add(lblGender, 0, 2);
        grid.add(genderBox, 1, 2);

        grid.add(lblYear, 0, 3);
        grid.add(cmbYear, 1, 3);

        grid.add(lblAddress, 0, 4);
        grid.add(txtAddress, 1, 4);

        grid.add(lblEmail, 0, 5);
        grid.add(txtEmail, 1, 5);

        grid.add(btnSave, 1, 6);

        Scene scene = new Scene(grid, 450, 400);
        primaryStage.setTitle("Student Registration");
        primaryStage.setScene(scene);
        primaryStage.show();
    }

    public static void main(String[] args) {
        launch(args);
    }
}
