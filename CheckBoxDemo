package Final;

import javafx.event.ActionEvent;
import javafx.event.EventHandler;
import javafx.scene.control.CheckBox;
import javafx.scene.layout.BorderPane;
import javafx.scene.layout.VBox;
import javafx.scene.text.Font;
import javafx.scene.text.FontPosture;
import javafx.scene.text.FontWeight;

public class CheckBoxDemo extends ButtonDemo {
	@Override
	protected BorderPane getPane() {
		BorderPane pane = super.getPane();
		
		VBox vbox = new VBox(20);
		CheckBox bold = new CheckBox("BOLD");
		CheckBox italic = new CheckBox("ITALIC");
		vbox.getChildren().addAll(bold, italic);
		vbox.setStyle("-fx-padding: 25, 25, 25, 25");
		
		pane.setRight(vbox);
		
		
		EventHandler<ActionEvent> handler = (e->{
			if(bold.isSelected() && italic.isSelected()) {
				Font both = Font.font("Times New Roman", FontWeight.BOLD, FontPosture.ITALIC, 20);
				text.setFont(both);
			}else if(bold.isSelected()) {
				Font bolded = Font.font("Times New Roman", FontWeight.BOLD, FontPosture.REGULAR ,20);
				text.setFont(bolded);
			}else if(italic.isSelected()) {
				Font italicfont = Font.font("Times New Roman", FontWeight.NORMAL, FontPosture.ITALIC, 20);
				text.setFont(italicfont);
			}else {
				Font normal = Font.font("Times New Roman", FontWeight.NORMAL, FontPosture.REGULAR, 20);
				text.setFont(normal);
			}
		});
		
		bold.setOnAction(handler);
		italic.setOnAction(handler);
			
		
		
		return pane;
		
	}
	
	public static void main(String[] args) {
		launch(args);
		
	}
}
